# BoondManager MCP server — environment template.
# Copy to `.env` and fill in. `.env` is gitignored; never commit secrets.
#
# The HTTP transport runs as an OAuth2 Authorization Server proxy:
# users click "Connect" on Dust, authenticate on BoondManager, and the
# server maps their Dust token to their BoondManager access token.

# ── Public URL (required in production) ────────────────────────────────────
# The externally-reachable URL of this server (no trailing slash).
# Used as the OAuth issuer, resource identifier, and base for all redirect URIs.
# On Railway this is typically https://<project>.up.railway.app
BASE_URL=https://your-app.up.railway.app

# Alternatively you can set the full MCP endpoint URL:
# MCP_HTTP_PUBLIC_URL=https://your-app.up.railway.app/mcp

# ── BoondManager OAuth app (required for OAuth proxy) ──────────────────────
# Register an OAuth app in the BoondManager developer portal and set the
# redirect URI to: https://your-app.up.railway.app/auth/callback
BOOND_OAUTH_CLIENT_ID=your_client_id
BOOND_OAUTH_CLIENT_SECRET=your_client_secret

# BoondManager OAuth endpoints (override if your tenant uses a custom URL)
# BOOND_OAUTH_AUTH_URL=https://ui.boondmanager.com/oauth/authorize
# BOOND_OAUTH_TOKEN_URL=https://ui.boondmanager.com/oauth/token

# Redirect URI registered in the BoondManager portal.
# Defaults to ${BASE_URL}/auth/callback if not set.
# BOOND_OAUTH_REDIRECT_URI=https://your-app.up.railway.app/auth/callback

# ── Server config ───────────────────────────────────────────────────────────
# PORT is set automatically by Railway; you can override with MCP_HTTP_PORT.
# PORT=3000

# ── Optional BoondManager API overrides ────────────────────────────────────
# BOOND_BASE_URL=https://ui.boondmanager.com/api

# ── Dust integration ────────────────────────────────────────────────────────
DUST_API_KEY=your_dust_api_key
DUST_WORKSPACE_ID=your_dust_workspace_id
# Base URL for the Dust API. Use https://eu.dust.tt for EU workspaces.
# DUST_BASE_URL=https://dust.tt
